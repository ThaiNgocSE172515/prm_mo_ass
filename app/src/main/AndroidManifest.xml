        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Prm_mo"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".TimelineDetailActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".HomeActivity"
            android:exported="false" />
        <activity
            android:name=".CreateRequestActivity"
            android:exported="false" />
        <activity
            android:name=".TeamHomeActivity"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".citizen.CitizenHomeActivity"
            android:exported="false" />
        <activity
            android:name=".citizen.CreateRequestActivity"
            android:exported="false" />
        <activity
            android:name=".RequestDetailActivity"
            android:exported="false" />
        <activity
            android:name=".coordinator.CoordinatorHomeActivity"
            android:exported="false" />
        <activity
            android:name=".TeamDetailActivity"
            android:exported="false" />
        <activity
            android:name=".MissionDetailActivity"
            android:exported="false" />
        <activity
            android:name=".TeamRequestHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".NotificationActivity"
            android:exported="false" />
    </application>

</manifest>