<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gửi yêu cầu"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_h1"
            android:textAppearance="@style/TextAppearance.App.H1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Chúng tôi sẽ hỗ trợ bạn sớm nhất có thể"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small"
            android:textAppearance="@style/TextAppearance.App.Small" />

        <!-- Section 1: Loại yêu cầu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRescue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius_small"
                app:strokeColor="@color/primary"
                app:strokeWidth="@dimen/input_stroke_width_focused">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cứu hộ"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Dành cho tình huống khẩn cấp cần cứu nạn ngay"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRelief"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/card_corner_radius_small"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cứu trợ"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Dành cho nhu yếu phẩm và hỗ trợ sinh hoạt"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Section 2: Chọn nhanh tình huống -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="2. Chọn nhanh tình huống cứu hộ"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_h3"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Ngập lụt -->
                <include
                    android:id="@+id/itemFlood"
                    layout="@layout/item_incident_type" />

                <!-- Bị kẹt -->
                <include
                    android:id="@+id/itemTrapped"
                    layout="@layout/item_incident_type" />

                <!-- Bị thương -->
                <include
                    android:id="@+id/itemInjured"
                    layout="@layout/item_incident_type" />

                <!-- Sạt lở -->
                <include
                    android:id="@+id/itemLandslide"
                    layout="@layout/item_incident_type" />

                <!-- Khác -->
                <include
                    android:id="@+id/itemOther"
                    layout="@layout/item_incident_type" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Section3: Thông tin chi tiết -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả tình huống *"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/input_background"
                    android:gravity="top"
                    android:hint="Nhập chi tiết tình huống của bạn..."
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:textSize="@dimen/text_body"
                    android:padding="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="0/500"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_caption" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:background="@color/divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số người cần hỗ trợ *"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPeopleCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/input_background"
                    android:hint="Ví dụ: 2"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:textSize="@dimen/text_body"
                    android:padding="@dimen/spacing_sm" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 4: Hình ảnh hiện trường -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCamera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/llCameraPrompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/text_tertiary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="Nhấn để chụp ảnh"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Chụp ảnh hiện trường để đội cứu hộ dễ hình dung"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivCapturedImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 5: Vị trí hiện tại -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="4. Vị trí hiện tại"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_h3"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/padding_card">

                <TextView
                    android:id="@+id/tvLocationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vị trí của bạn"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tvLocationDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvLocationTitle"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="Đang lấy vị trí..."
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:id="@+id/btnUpdateLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Cập nhật"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_small"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/spacing_xs" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:backgroundTint="@color/primary"
            android:text="Gửi yêu cầu ngay"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="@dimen/text_button"
            android:textStyle="bold"
            app:cornerRadius="@dimen/button_corner_radius" />

    </LinearLayout>
</ScrollView>
