<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDetailType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="Rescue" />

        <TextView
            android:id="@+id/tvDetailStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:color/holo_blue_light"
            android:padding="4dp"
            android:textColor="@android:color/white"
            android:text="SUBMITTED" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Incident Type:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailIncidentType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flood" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Description:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description detail here..." />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="People Count:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailPeopleCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Priority:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Created At:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailCreatedAt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-03-20" />

    </LinearLayout>
</ScrollView>