<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDetailType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="Rescue" />

        <TextView
            android:id="@+id/tvDetailStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:color/holo_blue_light"
            android:padding="4dp"
            android:textColor="@android:color/white"
            android:text="SUBMITTED" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Incident Type:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailIncidentType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flood" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Description:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description detail here..." />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="People Count:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailPeopleCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Priority:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Created At:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvDetailCreatedAt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026-03-20" />

        <LinearLayout
            android:id="@+id/llCoordinatorActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="2">

            <Button
                android:id="@+id/btnVerify"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#10B981"
                android:textColor="#FFFFFF"
                android:text="VERIFY (DUYỆT)" />

            <Button
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:backgroundTint="#EF4444"
                android:textColor="#FFFFFF"
                android:text="REJECT (TỪ CHỐI)" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>